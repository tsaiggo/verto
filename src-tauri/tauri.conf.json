{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Verto",
  "version": "../package.json",
  "identifier": "com.tsaiggo.verto",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build:tauri",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "Verto",
        "width": 1280,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "The MDX reader.",
    "longDescription": "Verto turns a folder of .mdx / .md files into a navigable, statically-rendered reader.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://github.com/tsaiggo/verto/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhEQUEzNDcxN0VFRUM0RUEKUldUcXhPNStjVFNxalpDMnhhWCt6YndYSmVVMUpwRFY1dnluczllMUhCNjRrWU9XQ2lIanV0QzcK"
    }
  }
}
