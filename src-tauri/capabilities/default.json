{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities granted to the main Verto window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "core:window:allow-is-maximized",
    "updater:default",
    "process:default",
    "process:allow-restart",
    "opener:default",
    "dialog:default",
    "dialog:allow-open",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://models.github.ai/*" },
        { "url": "https://*" },
        { "url": "https://*:*" },
        { "url": "http://*" },
        { "url": "http://*:*" }
      ]
    },
    "fs:allow-write-file",
    "fs:allow-mkdir",
    "fs:allow-read-file",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "$HOME/**" }]
    }
  ]
}
