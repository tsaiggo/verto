{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities granted to the main Verto window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "updater:default",
    "process:default",
    "process:allow-restart",
    "opener:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://github.com/*" },
        { "url": "https://api.github.com/*" }
      ]
    }
  ]
}
