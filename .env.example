# --------------------------------------------------------------------------
# Verto content source — pick one
# --------------------------------------------------------------------------
# Verto resolves its readable content (the `.md` / `.mdx` files behind the
# `/read/*` routes) through a pluggable "content source". By default it
# walks the local `./content` directory; you can switch to GitHub or
# OneDrive by setting `VERTO_CONTENT_SOURCE` and the matching env vars.

# local (default)  |  github  |  onedrive
VERTO_CONTENT_SOURCE=local

# Local source — VERTO_CONTENT_SOURCE=local
# --------------------------------------------------------------------------
# Folder Verto reads `.md` / `.mdx` files from. May be absolute or relative
# to the project root. Defaults to `./content` when unset.
# VERTO_LOCAL_DIR=content

# --------------------------------------------------------------------------
# AI assistant (GitHub Copilot / GitHub Models) — optional
# --------------------------------------------------------------------------
# Verto can show an "Ask AI" panel in the right rail that answers questions
# about the document being read, powered by GitHub Models (an OpenAI-compatible
# inference endpoint authenticated with a GitHub token). The feature is OFF
# unless NEXT_PUBLIC_VERTO_ASSISTANT is set.
#
#   none (default) | github   (aliases: copilot, github-models)
# NEXT_PUBLIC_VERTO_ASSISTANT=github
#
# Optional model override (defaults to openai/gpt-4o-mini):
# NEXT_PUBLIC_VERTO_ASSISTANT_MODEL=openai/gpt-4o-mini
#
# Credentials are NEVER stored in the repo:
#  • Desktop app — reuses the GitHub token from the device-flow sign-in.
#  • Web build  — the user pastes a GitHub token (Models access) that is kept
#    only in their browser's localStorage.

# --------------------------------------------------------------------------
# Desktop GitHub login (Tauri) — VERTO_CONTENT_SOURCE is not required
# --------------------------------------------------------------------------
# The desktop app can sign in interactively with a GitHub account (OAuth
# Device Flow) and connect to a repository at runtime — no token in env.
# This only needs the *public* OAuth App client id; there is no secret to
# ship. Register an OAuth App (enable "Device Flow") and set:
# NEXT_PUBLIC_VERTO_GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxx
# The signed-in token + chosen repo are stored on the host (app-data dir),
# never in the repository. The web/CI build keeps using the env vars below.

# --------------------------------------------------------------------------
# GitHub source — VERTO_CONTENT_SOURCE=github
# --------------------------------------------------------------------------
# A single Git Trees API call pulls the full file list, then each readable
# file is fetched as a blob on first access. Works for public repos with
# no token; set VERTO_GITHUB_TOKEN to raise the rate limit from 60/h to
# 5000/h (also required for private repos).

# VERTO_GITHUB_REPO=owner/repo
# VERTO_GITHUB_BRANCH=main
# VERTO_GITHUB_PATH=content
# VERTO_GITHUB_TOKEN=

# --------------------------------------------------------------------------
# OneDrive source — VERTO_CONTENT_SOURCE=onedrive
# --------------------------------------------------------------------------
# Two operating modes — pick whichever fits the deployment.

# (a) Share-URL mode — zero-config, works for anonymous share links.
# VERTO_ONEDRIVE_SHARE_URL=https://1drv.ms/u/s!...
# VERTO_ONEDRIVE_PATH=content

# (b) App + refresh-token mode — for private content. You need to register
# a Microsoft Entra (Azure AD) app and complete a one-off auth dance to
# obtain the refresh token; see README → Content Sources → OneDrive.
# VERTO_ONEDRIVE_TENANT=common
# VERTO_ONEDRIVE_CLIENT_ID=
# VERTO_ONEDRIVE_CLIENT_SECRET=
# VERTO_ONEDRIVE_REFRESH_TOKEN=
# VERTO_ONEDRIVE_PATH=content
