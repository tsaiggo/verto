# Verto content source
#
# Verto reads Markdown and MDX files from a configured source. The desktop
# product uses Local Library and RSS; OneDrive remains available for static
# source builds.

# local (default) | onedrive
VERTO_CONTENT_SOURCE=local

# Local source
# VERTO_LOCAL_DIR=content

# AI assistant
#
# The assistant is off until it is configured. The current provider is GitHub
# Models. Add the model token manually in Settings > AI & Agent; it is stored
# only in localStorage on the current device.
#
# none (default) | github (aliases: copilot, github-models)
# NEXT_PUBLIC_VERTO_ASSISTANT=github
# NEXT_PUBLIC_VERTO_ASSISTANT_MODEL=openai/gpt-4o-mini

# OneDrive source
#
# Share-URL mode:
# VERTO_ONEDRIVE_SHARE_URL=https://1drv.ms/u/s!...
# VERTO_ONEDRIVE_PATH=content
#
# Private content:
# VERTO_ONEDRIVE_TENANT=common
# VERTO_ONEDRIVE_CLIENT_ID=
# VERTO_ONEDRIVE_CLIENT_SECRET=
# VERTO_ONEDRIVE_REFRESH_TOKEN=
# VERTO_ONEDRIVE_PATH=content